# ── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Vercel: set these in Project → Settings → Environment Variables

# The Railway backend base URL (NO trailing slash, NO /api suffix)
# Example: https://agriconnect-backend-production.up.railway.app
VITE_API_BASE_URL=https://YOUR_RAILWAY_BACKEND_URL
